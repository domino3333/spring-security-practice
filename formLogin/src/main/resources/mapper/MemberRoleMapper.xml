<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.formLogin.mapper.MemberRoleMapper">


    <select id="readMemberRoleById" resultType="MemberRole">
        select mr.* from member m join member_role mr  on m.member_no = mr.member_no where m.id =#{id}
    </select>

</mapper>